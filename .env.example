# Wiki template — environment example
# Copy to .env and fill in the variables you need.

# --- Required for the wiki chatbot ---
ANTHROPIC_API_KEY=

# --- Wiki frontend customization (all optional) ---
# WIKI_NAME=My Project
# WIKI_TAGLINE=Internal knowledge base
# WIKI_ADMIN_USERNAME=admin
# WIKI_ADMIN_PASSWORD=change-me
# WIKI_SECRET_KEY=                # Flask session secret; defaults to a per-user dev value

# --- Research tools (optional, used by .agents/skills/research-tools/) ---
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
OXY_USERNAME=
OXY_PASSWORD=

# Optional fallback
OPENAI_API_KEY=

# Notes:
# - Only ANTHROPIC_API_KEY is required to run the wiki frontend.
# - Research tool keys are only needed if you use the matching capability.
# - Runtime-specific setup belongs in engine/runtimes/*.md.
# - Keep machine-local secrets out of committed files.
