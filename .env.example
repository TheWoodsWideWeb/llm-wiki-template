# Wiki template — environment template.
# Copy this file to `.env` and fill in the values you need.
# Only ANTHROPIC_API_KEY is strictly required (for the chatbot).

# ============================================================
# Required: chatbot
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Wiki frontend customization (all optional, with defaults)
# ============================================================
WIKI_NAME=Wiki
WIKI_TAGLINE=Internal knowledge base
WIKI_ADMIN_USERNAME=admin
WIKI_ADMIN_PASSWORD=admin123
# Flask session secret. Leave blank for a per-user dev default,
# or set to any long random string for production.
WIKI_SECRET_KEY=

# ============================================================
# Research toolchain (.agents/skills/research-tools/)
# Only fill in the ones for tools you'll actually use.
# ============================================================

# Firecrawl — web scraping + site map (used by `web-scrape`)
FIRECRAWL_API_KEY=

# SerpAPI — Google search, news, trends, YouTube search
SERPAPI_API_KEY=

# Perplexity — synthesized research via Sonar Pro
PERPLEXITY_API_KEY=

# xAI — X/Twitter search and post reading via Grok
XAI_API_KEY=

# Oxylabs proxy — Reddit search and comment fetching
OXY_USERNAME=
OXY_PASSWORD=

# OpenAI — optional fallback for some research workflows
OPENAI_API_KEY=
